<Window x:Class="Shikigami.Runner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shikigami" Height="680" Width="960"
        MinHeight="440" MinWidth="640"
        Background="#0b0e17"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Stats bar -->
            <RowDefinition Height="Auto"/>
            <!-- Log area (expands) -->
            <RowDefinition Height="*"/>
            <!-- Input panel (hidden by default) -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="#060a10" Padding="14,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="DotIndicator" Width="12" Height="12" Fill="#005c4d" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="SHIKIGAMI" FontFamily="Bahnschrift" FontSize="7" Foreground="#4a5a6e"/>
                        <TextBlock x:Name="HeaderName" Text="Shikigami" FontFamily="Bahnschrift" FontSize="14" FontWeight="Bold" Foreground="#00e5c0"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock x:Name="HeaderStatus" Text="starting" FontFamily="Consolas" FontSize="11"
                           Foreground="#4a5a6e" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <Border Grid.Row="0" Background="#005c4d" Height="1" VerticalAlignment="Bottom"/>

        <!-- ── Stats bar ── -->
        <Border Grid.Row="1" Background="#0f1420" Padding="14,8">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,24,0">
                    <TextBlock Text="ITERATION" FontFamily="Bahnschrift" FontSize="7" Foreground="#4a5a6e"/>
                    <TextBlock x:Name="StatIteration" Text="0" FontFamily="Bahnschrift" FontSize="13" FontWeight="Bold" Foreground="#00e5c0"/>
                </StackPanel>
                <StackPanel Margin="0,0,24,0">
                    <TextBlock Text="TOOLS" FontFamily="Bahnschrift" FontSize="7" Foreground="#4a5a6e"/>
                    <TextBlock x:Name="StatTools" Text="0" FontFamily="Bahnschrift" FontSize="13" FontWeight="Bold" Foreground="#5ec4ff"/>
                </StackPanel>
                <StackPanel Margin="0,0,24,0">
                    <TextBlock Text="COST" FontFamily="Bahnschrift" FontSize="7" Foreground="#4a5a6e"/>
                    <TextBlock x:Name="StatCost" Text="$0.00" FontFamily="Bahnschrift" FontSize="13" FontWeight="Bold" Foreground="#e5a000"/>
                </StackPanel>
                <StackPanel x:Name="TasksPanel" Margin="0,0,24,0" Visibility="Collapsed">
                    <TextBlock Text="TASKS" FontFamily="Bahnschrift" FontSize="7" Foreground="#4a5a6e"/>
                    <TextBlock x:Name="StatTasks" Text="0" FontFamily="Bahnschrift" FontSize="13" FontWeight="Bold" Foreground="#7dff7d"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Background="#161c2e" Height="1" VerticalAlignment="Bottom"/>

        <!-- ── Log area ── -->
        <ScrollViewer x:Name="LogScroller" Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="#0b0e17">
            <RichTextBox x:Name="LogBox" Background="#0b0e17" Foreground="#b8c5d6"
                         FontFamily="Consolas" FontSize="10" IsReadOnly="True" BorderThickness="0"
                         Padding="14,4" VerticalScrollBarVisibility="Disabled">
                <RichTextBox.Document>
                    <FlowDocument PageWidth="5000"/>
                </RichTextBox.Document>
            </RichTextBox>
        </ScrollViewer>

        <!-- ── Input panel ── -->
        <Border x:Name="InputPanel" Grid.Row="3" Background="#161c2e" Padding="14,8" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputBox" Grid.Column="0" Background="#0f1420" Foreground="#e4eaf4"
                         FontFamily="Consolas" FontSize="11" Padding="8,6" BorderThickness="1"
                         BorderBrush="#005c4d" CaretBrush="#00e5c0"
                         KeyDown="InputBox_KeyDown"/>
                <Button x:Name="SendButton" Grid.Column="1" Content="Send" Margin="8,0,0,0"
                        Background="#005c4d" Foreground="#00e5c0" FontFamily="Bahnschrift"
                        Padding="16,6" BorderThickness="0" Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
